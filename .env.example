# Copy to .env.local (gitignored) — never commit real keys

# Supabase (beaverr project, eu-west-1)
EXPO_PUBLIC_SUPABASE_URL=https://fetbfivnidpaxcsadnnb.supabase.co
# Legacy anon JWT from Dashboard → API Keys (recommended for Auth)
# Do NOT wrap the value in angle brackets — paste the key only.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Auth — local dev: Dashboard → Authentication → Providers → Email → disable "Confirm email"
# so sign-up returns a session and goes straight to onboarding. Re-enabling confirmation later
# requires a check-email screen plus custom SMTP (Resend/SendGrid) — not the built-in mailer.

# Optional — mobile web only when you mistakenly open localhost on a phone (desktop should leave this unset):
# EXPO_PUBLIC_AUTH_REDIRECT_ORIGIN=http://192.168.1.42:8081

# Google Cloud Vertex Gemini — EU multi-region (eval + production path)
GOOGLE_CLOUD_PROJECT=beaverr
# GEMINI_LOCATION=eu
# GEMINI_VERTEX_HOST=https://aiplatform.eu.rep.googleapis.com
# Optional explicit token (else uses ADC: gcloud auth application-default login):
# GEMINI_ACCESS_TOKEN=
# Legacy AI Studio only (deprecated):
# GEMINI_API_KEY=
# Optional override:
# GEMINI_MODEL=gemini-3.1-flash-lite
